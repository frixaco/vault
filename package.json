{
  "name": "vault-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop, mobile, and sync API workspace.",
  "type": "module",
  "scripts": {
    "dev-desktop": "pnpm --filter @vault/desktop dev",
    "dev-mobile": "pnpm --filter @vault/mobile dev",
    "dev-sync-api": "pnpm --filter @vault/sync-api dev",
    "fmt": "oxfmt --check .",
    "fmt-fix": "oxfmt --write .",
    "lint": "oxlint .",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@typescript/native-preview": "beta",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=11.0.0-rc.5"
  },
  "packageManager": "pnpm@11.0.0-rc.5"
}
