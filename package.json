{
  "name": "vault-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop, mobile, and sync API workspace.",
  "type": "module",
  "scripts": {
    "android": "pnpm --filter @vault/mobile android",
    "ios": "pnpm --filter @vault/mobile ios",
    "build-desktop": "pnpm --filter @vault/desktop build",
    "build-native": "pnpm build-vault-shared",
    "dev-desktop": "pnpm --filter @vault/desktop dev",
    "dev-mobile": "pnpm --filter @vault/mobile dev",
    "dev-sync-api": "pnpm --filter @vault/sync-api dev",
    "build-vault-shared": "node scripts/build-vault-shared.mjs",
    "dist-desktop-linux": "pnpm --filter @vault/desktop dist-linux",
    "dist-desktop-mac": "pnpm --filter @vault/desktop dist-mac",
    "dist-desktop-mac-arm64": "pnpm --filter @vault/desktop dist-mac-arm64",
    "dist-desktop-mac-universal": "pnpm --filter @vault/desktop dist-mac-universal",
    "dist-desktop-mac-x64": "pnpm --filter @vault/desktop dist-mac-x64",
    "dist-desktop-win": "pnpm --filter @vault/desktop dist-win",
    "dist-desktop-win-arm64": "pnpm --filter @vault/desktop dist-win-arm64",
    "dist-desktop-win-x64": "pnpm --filter @vault/desktop dist-win-x64",
    "fmt": "oxfmt --check .",
    "fmt-fix": "oxfmt --write .",
    "lint": "oxlint --ignore-pattern 'desktop/dist-electron/**' --ignore-pattern 'desktop/dist-renderer/**' .",
    "measure-desktop-mac": "tsx scripts/desktop-release-memory.ts",
    "typecheck": "pnpm typecheck-scripts && pnpm -r --if-present typecheck",
    "typecheck-scripts": "tsgo -p scripts/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@typescript/native-preview": "beta",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "oxlint-tailwindcss": "0.6.3",
    "tsx": "4.21.0"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.0.0"
}
